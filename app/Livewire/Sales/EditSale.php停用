<?php // app/Livewire/Sales/EditSale.php

namespace App\Livewire\Sales;

use Livewire\Component;
use App\Models\Sale;
use App\Models\Customer;
use App\Models\Product;
use Mary\Traits\Toast;
use Illuminate\Support\Facades\DB;

class EditSale extends Component
{
    use Toast;

    public $sold_at;
    public $customer_id;
    public $invoice_number;
    public $items = []; 
    public $products;
	public $channel;
	public $payment_method;
	
    public $subtotal = '0.00'; 
    public $discount = 0;
    public $platform_coupon = 0;
    public $shipping_fee_customer = 0;
    public $shipping_fee_platform = 0;
    public $platform_fee = 0;
	public $order_adjustment = 0;
	public $customer_total = '0.00';
	
    public Sale $sale; // 宣告為 Sale 物件

	public function mount(Sale $sale)
	{
		$this->sale = $sale ?? new Sale();
		
		// 如果 $sale 存在於資料庫，Livewire 會自動透過路由 ID 抓取
		if ($this->sale->exists) {
			$this->sale = $sale->load('items.product');
			
			// 賦值給表單欄位，否則畫面會是空的（看起來像新增）
			$this->customer_id = $sale->customer_id;
			$this->invoice_number = $sale->invoice_number;
			$this->channel = $sale->channel;
			$this->payment_method = $sale->payment_method;
			$this->sold_at = $sale->sold_at->format('Y-m-d');
			
			// 載入金額
			$this->subtotal = $sale->subtotal;
			$this->discount = $sale->discount;
			$this->platform_coupon = $sale->platform_coupon;
			$this->shipping_fee_customer = $sale->shipping_fee_customer;
			$this->shipping_fee_platform = $sale->shipping_fee_platform;
			$this->platform_fee = $sale->platform_fee;
			$this->order_adjustment = $sale->order_adjustment;

			// 填充明細陣列
			$this->items = $sale->items->map(fn($item) => [
				'product_id' => $item->product_id,
				'quantity'   => (float)$item->quantity,
				'price'      => (float)$item->price,
			])->toArray();
			
			// 4. 解決搜尋欄未顯示：將已存在的商品放入 $products 列表
			$productIds = collect($this->items)->pluck('product_id')->filter();
			$this->products = Product::whereIn('id', $productIds)
				->get()
				->map(function ($p) {
					return [
						'id' => $p->id,
						'name' => "{$p->sku}：{$p->name}", 
						'sku' => $p->sku
					];
				});
				
			$this->calculateTotal(); // 執行初始計算
		} else {
			// 新增模式的初始化
			$this->sold_at = date('Y-m-d');
			$this->items = [['product_id' => '', 'quantity' => 1, 'price' => 0]];
			$this->search(); // 載入預設可選商品
		}		
	}

    public function removeItem($index)
    {
        unset($this->items[$index]);
        $this->items = array_values($this->items);
        $this->calculateTotal();
    }

    /**
     * 修正：精準監聽 items 的變化
     */
    public function updated($propertyName)
	{
		// 精確匹配 items.數字.product_id 的變動
		if (preg_match('/items\.(\d+)\.product_id/', $propertyName, $matches)) {
			$index = $matches[1];
			$productId = $this->items[$index]['product_id'];

			if ($productId) {
				$product = \App\Models\Product::find($productId);
				if ($product) {
					// 自動帶入單價與顯示名稱
					$this->items[$index]['price'] = $product->price;		
				}
			}
		} // 這裡只有一個結束括號

		// 只要有任何更新，就重新計算總計
		$this->calculateTotal();
	}

    public function calculateTotal()
    {
        // 商品小計
		$this->subtotal = collect($this->items)->reduce(function ($carry, $item) {
			return bcadd($carry, bcmul((string)($item['quantity'] ?? 0), (string)($item['price'] ?? 0), 2), 2);
		}, '0.00');

		// 買家支付總額 = 小計 + 買家運費 - 賣場優惠($discount) - 平台優惠($platform_coupon)
		$buy = bcadd($this->subtotal, (string)$this->shipping_fee_customer, 2);
		$buy = bcsub($buy, (string)$this->discount, 2);
		$this->customer_total = bcsub($buy, (string)$this->platform_coupon, 2);
    }


	public function save()
	{
		// 1. 基本驗證
		$validatedData = $this->validate([
			'customer_id'           => 'required',
			'sold_at'               => 'required|date',
			'channel'               => 'required',
			'payment_method'        => 'required',
			'items'                 => 'required|array|min:1',
			'items.*.product_id'    => 'required',
			'items.*.quantity'      => 'required|numeric|min:1',
			'items.*.price'         => 'required|numeric',
		]);

		// 2. 準備要寫入資料庫的資料陣列
		$data = [
			'customer_id'           => $this->customer_id,
			'invoice_number'        => $this->invoice_number,
			'channel'               => $this->channel,
			'payment_method'        => $this->payment_method,
			'subtotal'              => $this->subtotal,
			'discount'              => $this->discount,
			'platform_coupon'       => $this->platform_coupon,
			'shipping_fee_customer' => $this->shipping_fee_customer,
			'shipping_fee_platform' => $this->shipping_fee_platform,
			'platform_fee'          => $this->platform_fee,
			'order_adjustment'      => $this->order_adjustment,
			'sold_at'               => $this->sold_at,
		];

		try {
			// 3. 判斷是「更新舊單」還是「新增新單」
			// 邏輯關鍵：如果是從 route 傳入的 $sale 物件，則執行更新
			if ($this->sale && $this->sale->exists) {
				$this->sale->updateWithCalculations($data, $this->items);
				$this->success('訂單已成功更新');
			} else {
				Sale::createWithCalculations($data, $this->items);
				$this->success('新訂單已成功建立');
			}

			return redirect()->route('sales.index');
			
		} catch (\Exception $e) {
			// 這裡會抓到 Model 拋出的「庫存不足」或其他錯誤
			$this->error($e->getMessage());
		}
	}

	public function search(string $value = '')
	{
		$this->products = Product::query()
			->withSum(['inventories as stock' => function($query) {
				$query->where('status', 'in_stock');
			}], 'quantity')
			->where('sku', 'like', "%{$value}%")
			->orWhere('name', 'like', "%{$value}%")
			->take(10)
			->get()
			->map(function ($p) {
				$stock = $p->stock ?? 0;
				return [
					'id' => $p->id,
					'name' => "{$p->sku}：{$p->name} (庫存: {$stock})", // 讓使用者選購時心裡有數
					'sku' => $p->sku,
					'pure_name' => $p->name
				];
			});
	}

	public function render()
	{
		return view('livewire.sales.quick-sale', [
			'customers' => Customer::all(),
			// 移除這裡的 'products'，因為已經存成屬性了
		]);
	}
}